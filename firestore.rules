// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: categories
// Fields: id, name, uid
//
// Collection: tasks
// Fields: id, name, income, link, categoryId, createdAt, uid
//
// Collection: devices
// Fields: id, name, uid
//
// Collection: accounts
// Fields: id, deviceId, siteName, email, password, link, uid
//
// Collection: notes
// Fields: id, name, content, uid
//
// Collection: links
// Fields: id, name, url, uid
//
// Collection: reports
// Fields: id, taskId, taskName, timestamp, uid
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      // শুধুমাত্র নির্দিষ্ট অ্যাডমিন ইমেইলকে অ্যাডমিন হিসেবে গণ্য করুন
      return isAuthenticated() && (request.auth.token.email == "muhammadalaminmeer@gmail.com" || request.auth.token.email == "alaminmir209@gmail.com" || request.auth.token.email == "muhammadalaminmeer@gmail.com");
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidCategory(data) {
      return hasRequiredFields(['id', 'name', 'uid']) &&
             hasOnlyAllowedFields(['id', 'name', 'uid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.uid is string;
    }

    function isValidTask(data) {
      return hasRequiredFields(['id', 'name', 'income', 'categoryId', 'createdAt', 'uid']) &&
             hasOnlyAllowedFields(['id', 'name', 'income', 'link', 'categoryId', 'createdAt', 'uid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.income is number &&
             data.categoryId is string &&
             data.createdAt is string &&
             data.uid is string;
    }

    function isValidDevice(data) {
      return hasRequiredFields(['id', 'name', 'uid']) &&
             hasOnlyAllowedFields(['id', 'name', 'uid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.uid is string;
    }

    function isValidAccount(data) {
      return hasRequiredFields(['id', 'deviceId', 'siteName', 'email', 'password', 'uid']) &&
             hasOnlyAllowedFields(['id', 'deviceId', 'name', 'siteName', 'email', 'password', 'link', 'notes', 'uid']) &&
             data.id is string &&
             data.deviceId is string && data.deviceId.size() > 0 &&
             (!('name' in data) || (data.name is string && data.name.size() < 100)) &&
             data.siteName is string && data.siteName.size() > 0 && data.siteName.size() < 100 &&
             data.email is string && data.email.size() > 0 &&
             data.password is string && data.password.size() > 0 &&
             (!('link' in data) || data.link is string) &&
             (!('notes' in data) || data.notes is string) &&
             data.uid is string;
    }

    function isValidNote(data) {
      return hasRequiredFields(['id', 'name', 'content', 'uid']) &&
             hasOnlyAllowedFields(['id', 'name', 'content', 'uid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.content is string && data.content.size() < 10000 &&
             data.uid is string;
    }

    function isValidLink(data) {
      return hasRequiredFields(['id', 'name', 'url', 'uid']) &&
             hasOnlyAllowedFields(['id', 'name', 'url', 'uid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.url is string &&
             data.uid is string;
    }

    function isValidReport(data) {
      return hasRequiredFields(['id', 'taskId', 'taskName', 'income', 'deviceId', 'deviceName', 'timestamp', 'uid']) &&
             hasOnlyAllowedFields(['id', 'taskId', 'taskName', 'income', 'deviceId', 'deviceName', 'accountId', 'accountEmail', 'timestamp', 'uid']) &&
             data.taskName is string &&
             data.income is number &&
             data.deviceId is string &&
             data.deviceName is string &&
             data.timestamp is string &&
             data.uid is string;
    }

    function isValidIssue(data) {
      return hasRequiredFields(['id', 'taskId', 'taskName', 'message', 'timestamp', 'status', 'uid']) &&
             hasOnlyAllowedFields(['id', 'taskId', 'taskName', 'message', 'timestamp', 'status', 'uid']) &&
             data.taskId is string &&
             data.taskName is string && data.taskName.size() < 200 &&
             data.message is string && data.message.size() < 5000 &&
             data.timestamp is string &&
             data.status in ['pending', 'resolved'] &&
             data.uid is string;
    }

    function isValidActivity(data) {
      return hasRequiredFields(['id', 'type', 'action', 'name', 'timestamp', 'uid']) &&
             hasOnlyAllowedFields(['id', 'type', 'action', 'name', 'timestamp', 'uid']) &&
             data.id is string &&
             data.type is string &&
             data.type in ['task', 'account', 'note', 'link', 'category', 'device', 'tasks', 'accounts', 'notes', 'links', 'categories', 'devices'] &&
             data.action is string &&
             data.action in ['create', 'update', 'delete'] &&
             data.name is string &&
             data.timestamp is string &&
             data.uid is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCategory(request.resource.data) && uidUnchanged();
      allow update: if isOwner(resource.data.uid) && isValidCategory(request.resource.data) && uidNotModified();
      allow delete: if isOwner(resource.data.uid);
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTask(request.resource.data) && uidUnchanged();
      allow update: if isOwner(resource.data.uid) && isValidTask(request.resource.data) && uidNotModified();
      allow delete: if isOwner(resource.data.uid);
    }

    match /devices/{deviceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidDevice(request.resource.data) && uidUnchanged();
      allow update: if isOwner(resource.data.uid) && isValidDevice(request.resource.data) && uidNotModified();
      allow delete: if isOwner(resource.data.uid);
    }

    match /accounts/{accountId} {
      allow get: if isOwner(resource.data.uid);
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAccount(request.resource.data) && uidUnchanged();
      allow update: if isOwner(resource.data.uid) && isValidAccount(request.resource.data) && uidNotModified() && areImmutableFieldsUnchanged(['id', 'uid']);
      allow delete: if isOwner(resource.data.uid);
    }

    match /notes/{noteId} {
      allow get: if isOwner(resource.data.uid);
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidNote(request.resource.data) && uidUnchanged();
      allow update: if isOwner(resource.data.uid) && isValidNote(request.resource.data) && uidNotModified() && areImmutableFieldsUnchanged(['id', 'uid']);
      allow delete: if isOwner(resource.data.uid);
    }

    match /links/{linkId} {
      allow get: if isOwner(resource.data.uid);
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidLink(request.resource.data) && uidUnchanged();
      allow update: if isOwner(resource.data.uid) && isValidLink(request.resource.data) && uidNotModified() && areImmutableFieldsUnchanged(['id', 'uid']);
      allow delete: if isOwner(resource.data.uid);
    }

    match /reports/{reportId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuthenticated() && isValidReport(request.resource.data) && uidUnchanged();
      allow update: if isOwner(resource.data.uid) && isValidReport(request.resource.data) && uidNotModified();
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /issues/{issueId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidIssue(request.resource.data) && uidUnchanged();
      allow update: if (isOwner(resource.data.uid) || isAdmin()) && isValidIssue(request.resource.data) && uidNotModified();
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidActivity(request.resource.data) && uidUnchanged();
      allow update: if isAdmin() && isValidActivity(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }
  }
}
